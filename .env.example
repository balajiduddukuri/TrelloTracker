# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TRELLO_API_KEY: Trello API Key from https://trello.com/app-key
TRELLO_API_KEY="abcdefghijklmnopqrstuvwxyz"

# TRELLO_TOKEN: Trello API Token from https://trello.com/app-key
TRELLO_TOKEN="abcdefghijklmnopqrstuvwxyz"

# TRELLO_BOARDS: Comma-separated list of Trello Board IDs to track
TRELLO_BOARDS="abcdefghijklmnopqrstuvwxyz"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
